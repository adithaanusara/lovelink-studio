generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Theme {
  romantic
  dreamy
  elegant
  cute
}

model MemoryProject {
  id          String      @id @default(cuid())
  slug        String      @unique
  title       String
  recipient   String
  sender      String
  occasion    String
  message     String      @db.Text
  accentText  String?
  musicUrl    String?
  eventDate   DateTime?
  theme       Theme       @default(romantic)
  coverImage  String
  gallery     GalleryImage[]
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
}

model GalleryImage {
  id         String        @id @default(cuid())
  imageUrl   String
  altText    String?
  sortOrder  Int           @default(0)
  projectId  String
  project    MemoryProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdAt  DateTime      @default(now())
}
