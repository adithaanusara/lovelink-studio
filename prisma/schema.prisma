generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Theme {
  romantic
  dreamy
  elegant
  cute
}

model MemoryProject {
  id          String         @id @default(cuid())
  slug        String         @unique
  title       String
  recipient   String
  sender      String
  occasion    String
  message     String
  accentText  String?
  musicUrl    String?
  eventDate   DateTime?
  theme       String
  coverImage  String
  layoutJson  Json?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  gallery     GalleryImage[]
}

model GalleryImage {
  id         String   @id @default(cuid())
  imageUrl    String
  altText     String?
  sortOrder   Int
  projectId   String
  createdAt   DateTime @default(now())
  project     MemoryProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
}